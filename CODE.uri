data:text/html, <title>Pro Editor</title><body style="margin:0;display:flex;flex-direction:column;height:100vh;font-family:sans-serif;background:%23f4f4f9;"><div style="flex:0 0 auto;background:%23333;display:flex;flex-direction:column;z-index:100;"><div style="background:%23007bff;padding:10px;display:flex;justify-content:space-between;align-items:center;"><div style="display:flex;align-items:center;gap:10px;"><span style="color:white;font-weight:bold;margin-left:5px;">Pro Editor</span><button onclick="document.getElementById('m').style.display='flex'" style="color:white;background:rgba(255,255,255,0.2);border:1px solid white;border-radius:5px;padding:4px 8px;font-weight:bold;font-size:0.7rem;cursor:pointer;">Info</button></div><div style="display:flex;gap:5px;"><button onclick="cp('md')" style="color:white;background:rgba(255,255,255,0.2);border:1px solid white;border-radius:5px;padding:8px;font-weight:bold;font-size:0.8rem;">Copy MD</button><button onclick="cp('plain')" style="color:white;background:rgba(255,255,255,0.2);border:1px solid white;border-radius:5px;padding:8px;font-weight:bold;font-size:0.8rem;">Copy Plain</button></div></div><div style="padding:8px;display:flex;overflow-x:auto;white-space:nowrap;gap:6px;background:%23444;"><button onclick="document.execCommand('bold')">B</button><button onclick="document.execCommand('italic')"><i>I</i></button><button onclick="document.execCommand('underline')">U</button><button onclick="document.execCommand('strikeThrough')"><s>S</s></button><button onclick="document.execCommand('insertUnorderedList')">List</button><button onclick="document.execCommand('formatBlock',false,'h1')">H1</button><button onclick="document.execCommand('formatBlock',false,'h2')">H2</button><button onclick="document.execCommand('formatBlock',false,'p')">Para</button></div></div><div id="edit" contenteditable onfocus="if(this.innerText==='Type here...'){this.innerText='';}" style="flex:1 1 auto;font-size:2rem;line-height:1.5;max-width:60rem;width:100%;margin:0 auto;padding:2rem;outline:none;background:white;overflow-y:auto;box-sizing:border-box;">Type here...</div><div id="m" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:1000;justify-content:center;align-items:center;" onclick="this.style.display='none'"><div style="background:white;padding:2rem;border-radius:10px;text-align:center;max-width:80%;" onclick="event.stopPropagation()"><p style="font-size:1.2rem;margin-bottom:1.5rem;color:%23333;">More info at GitHub:</p><a href="https://github.com/zaniestp" target="_blank" style="display:inline-block;padding:10px 20px;background:%23007bff;color:white;text-decoration:none;border-radius:5px;font-weight:bold;margin-bottom:1rem;">Visit GitHub Profile</a><br><button onclick="document.getElementById('m').style.display='none'" style="background:%23eee;padding:5px 15px;border-radius:5px;border:none;cursor:pointer;">Close</button></div></div><script>function cp(mode){const el=document.getElementById('edit');let t=el.innerHTML;if(mode==='md'){t=t.replace(/<(b|strong)>(.*?)<\/\1>/gi,'**$2**').replace(/<(i|em)>(.*?)<\/\1>/gi,'*$2*').replace(/<(s|strike|del)>(.*?)<\/\1>/gi,'~~$2~~').replace(/<u>(.*?)<\/u>/gi,'_$1_').replace(/<h1>(.*?)<\/h1>/gi,'%23 $1\n').replace(/<h2>(.*?)<\/h2>/gi,'%23%23 $1\n').replace(/<li>(.*?)<\/li>/gi,'- $1\n').replace(/<br>|<div>/gi,'\n').replace(/<[^>]+>/g,'');}else{t=el.innerText;}const a=document.createElement('textarea');a.value=t.replace(/&nbsp;/g,' ').trim();document.body.appendChild(a);a.select();document.execCommand('copy');document.body.removeChild(a);alert('Copied as '+mode);}</script><style>button{border-radius:4px;border:none;background:%23eee;font-weight:bold;font-size:0.9rem;padding:8px 12px;cursor:pointer;flex:0 0 auto;}</style></body>
